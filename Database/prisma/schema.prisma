generator client {
  provider = "prisma-client-js"
  output   = "../../Frontend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  password         String
  role             Role           @default(STUDENT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  username         String         @unique
  studentProfile   Student?
  teacherProfile   Teacher?
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
}


model Student {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  userId    String   @unique
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  grades    Grade[]
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Teacher {
  id          String              @id @default(cuid())
  firstName   String
  lastName    String
  userId      String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id])
  assignments TeacherAssignment[]
}

model Course {
  id          String              @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  students    Student[]
  assignments TeacherAssignment[]
}

model Subject {
  id              String              @id @default(cuid())
  name            String
  gradingConfigId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  gradingConfig   GradingConfig       @relation(fields: [gradingConfigId], references: [id])
  assignments     TeacherAssignment[]
}

model TeacherAssignment {
  id             String          @id @default(cuid())
  teacherId      String
  courseId       String
  subjectId      String
  accessRequests AccessRequest[]
  grades         Grade[]
  course         Course          @relation(fields: [courseId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  teacher        Teacher         @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, courseId, subjectId])
}

model AcademicYear {
  id        String           @id @default(cuid())
  name      String
  isActive  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  periods   AcademicPeriod[]
}

model AcademicPeriod {
  id             String          @id @default(cuid())
  name           String
  weight         Float
  academicYearId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  status         PeriodStatus    @default(OPEN)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  accessRequests AccessRequest[]
  grades         Grade[]
}

model AccessRequest {
  id           String            @id @default(cuid())
  assignmentId String
  periodId     String
  reason       String
  status       RequestStatus     @default(PENDING)
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
}

model SchoolInfo {
  id         String   @id @default("institutional-info")
  name       String   @default("Nombre del Colegio")
  nit        String?
  address    String?
  phone      String?
  email      String?
  rectorName String?
  logo       String?
  updatedAt  DateTime @updatedAt
}

model GradingConfig {
  id            String    @id @default(cuid())
  name          String
  type          String
  minValue      Float?
  maxValue      Float?
  allowedValues String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  subjects      Subject[]
}

model Grade {
  id           String            @id @default(cuid())
  studentId    String
  assignmentId String
  value        String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  periodId     String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])

  @@unique([studentId, assignmentId, periodId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Message {
  id          String       @id @default(cuid())
  subject     String
  content     String       @db.Text
  senderId    String
  receiverId  String
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  sender      User         @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Attachment {
  id        String  @id @default(cuid())
  name      String
  type      String
  data      String  @db.Text
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

