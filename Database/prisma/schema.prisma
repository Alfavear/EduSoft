generator client {
  provider = "prisma-client-js"
  output   = "../../Frontend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  password         String
  role             Role           @default(STUDENT)
  image            String?        // Profile image (base64 or URL)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  username         String         @unique
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  studentProfile   Student?
  teacherProfile   Teacher?
}

model Student {
  id            String       @id @default(cuid())
  firstName     String
  lastName      String
  documentId    String?
  guardianName  String       @default("No registrado")
  guardianPhone String       @default("0000000000")
  guardianEmail String?
  address       String?
  bloodType     String?
  birthDate     DateTime?
  userId        String       @unique
  courseId      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attendances   Attendance[]
  grades        Grade[]
  course        Course       @relation(fields: [courseId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
}

model Teacher {
  id              String              @id @default(cuid())
  firstName       String
  lastName        String
  documentId      String?
  phone           String?
  address         String?
  specialization  String?
  userId          String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  attendances     Attendance[]
  attendanceReqs  AttendanceRequest[]
  directedCourses Course[]            @relation("CourseDirector")
  user            User                @relation(fields: [userId], references: [id])
  assignments     TeacherAssignment[]
}

model Course {
  id             String              @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  directorId     String?
  attendances    Attendance[]
  attendanceReqs AttendanceRequest[]
  director       Teacher?            @relation("CourseDirector", fields: [directorId], references: [id])
  students       Student[]
  assignments    TeacherAssignment[]
}

model Subject {
  id              String              @id @default(cuid())
  name            String
  gradingConfigId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  gradingConfig   GradingConfig       @relation(fields: [gradingConfigId], references: [id])
  assignments     TeacherAssignment[]
}

model TeacherAssignment {
  id             String          @id @default(cuid())
  teacherId      String
  courseId       String
  subjectId      String
  accessRequests AccessRequest[]
  grades         Grade[]
  course         Course          @relation(fields: [courseId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  teacher        Teacher         @relation(fields: [teacherId], references: [id])
  scheduleItems  ScheduleItem[]

  @@unique([teacherId, courseId, subjectId])
}

model AcademicYear {
  id        String           @id @default(cuid())
  name      String
  isActive  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  periods   AcademicPeriod[]
}

model AcademicPeriod {
  id             String          @id @default(cuid())
  name           String
  weight         Float
  academicYearId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  status         PeriodStatus    @default(OPEN)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  accessRequests AccessRequest[]
  grades         Grade[]
}

model AccessRequest {
  id           String            @id @default(cuid())
  assignmentId String
  periodId     String
  reason       String
  status       RequestStatus     @default(PENDING)
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
}

model SchoolInfo {
  id                  String   @id @default("institutional-info")
  name                String   @default("Nombre del Colegio")
  nit                 String?
  address             String?
  phone               String?
  email               String?
  rectorName          String?
  logo                String?
  updatedAt           DateTime @updatedAt
  alertThreshold      Float    @default(3.0)
  attendanceLimitDays Int      @default(1)
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus
  teacherId String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])
  teacher   Teacher?         @relation(fields: [teacherId], references: [id])

  @@unique([studentId, courseId, date])
}

model AttendanceRequest {
  id        String        @id @default(cuid())
  teacherId String
  courseId  String
  date      DateTime
  reason    String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  course    Course        @relation(fields: [courseId], references: [id])
  teacher   Teacher       @relation(fields: [teacherId], references: [id])
}

model GradingConfig {
  id            String    @id @default(cuid())
  name          String
  type          String
  minValue      Float?
  maxValue      Float?
  allowedValues String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  subjects      Subject[]
}

model Grade {
  id           String            @id @default(cuid())
  studentId    String
  assignmentId String
  value        String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  periodId     String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])

  @@unique([studentId, assignmentId, periodId])
}

model Message {
  id          String       @id @default(cuid())
  subject     String
  content     String
  senderId    String
  receiverId  String
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender      User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Attachment {
  id        String  @id @default(cuid())
  name      String
  type      String
  data      String
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        EventType @default(OTHER)
  isGlobal    Boolean   @default(true)
  targetRole  Role?     // If null, visible to all in the scope
  courseId    String?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScheduleItem {
  id           String            @id @default(cuid())
  dayOfWeek    Int
  startTime    String
  endTime      String
  assignmentId String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([dayOfWeek, startTime, assignmentId])
}

enum EventType {
  MEETING
  BULLETIN_DELIVERY
  PEDAGOGICAL_DAY
  HOLIDAY
  OTHER
}

model PasswordResetRequest {
  id              String        @id @default(cuid())
  documentType    String
  documentId      String
  status          RequestStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
