generator client {
  provider = "prisma-client-js"
  output   = "../../Frontend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  password         String
  role             Role           @default(STUDENT)
  image            String? // Profile image (base64 or URL)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  username         String         @unique
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  auditLogs        AuditLog[]
  studentProfile   Student?
  teacherProfile   Teacher?
}

model Student {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  documentId     String?
  documentType   String?         // CC, TI, RC, NES, etc.
  gender         String?         // M, F, OTRO
  stratus        Int?            // 1-6
  sisben         String?         // A1, B2, etc.
  eps            String?
  ethnicity      String?
  disability     String?
  isVictim       Boolean         @default(false)
  guardianName   String          @default("No registrado")
  guardianPhone  String          @default("0000000000")
  guardianEmail  String?
  address        String?
  bloodType      String?
  birthDate      DateTime?
  
  // --- Campos SIMAT / Anexo 6A ---
  paeBeneficiary    Boolean      @default(false)
  transportBeneficiary Boolean   @default(false)
  disabilityType    String?      // CIE-10 o categorías MEN
  isDisplaced       Boolean      @default(false)
  ethnicGroup       String?      // Indígena, Afro, etc.
  extracurricular   String?      // Actividades complementarias
  
  observations   Observation[]
  parentMeetings ParentMeeting[]
  isConditional  Boolean         @default(false)
  userId         String          @unique
  courseId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attendances    Attendance[]
  grades         Grade[]
  invoices       Invoice[]
  enrollments     Enrollment[]
  documentChanges  DocumentChange[]
  officialDocuments OfficialDocument[]
  course          Course          @relation(fields: [courseId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
}

model OfficialDocument {
  id           String   @id @default(cuid())
  studentId    String?
  enrollmentId String?
  name         String   // Ej: "Documento Identidad", "Seguro Médico"
  fileUrl      String   // Ruta local o URL de almacenamiento
  fileType     String   // "PDF", "JPG", etc.
  createdAt    DateTime @default(now())
  
  student      Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}



model DocumentChange {
  id             String    @id @default(cuid())
  studentId      String
  oldDocumentId  String
  oldDocumentType String
  newDocumentId  String
  newDocumentType String
  changeDate     DateTime  @default(now())
  reason         String?   // Ej: "Cambio de RC a TI"
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}


model Enrollment {
  id              String           @id @default(cuid())
  studentId       String
  academicYearId  String
  courseId        String
  status          EnrollmentStatus @default(ENROLLED)
  enrollmentDate  DateTime         @default(now())
  
  // Normativa Decreto 1290 (Colombia)
  finalAverage    Float?
  nationalScale   String?          // Superior, Alto, Básico, Bajo
  promotionDate   DateTime?
  prematriculaUrl String?          // Documento de prematrícula (Requisito antiguos)
  notes           String?
  
  student       Student      @relation(fields: [studentId], references: [id])
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id])
  course        Course       @relation(fields: [courseId], references: [id])
  remedials     RemedialSession[]
  officialDocuments OfficialDocument[]

  @@unique([studentId, academicYearId])
}

model RemedialSession {
  id           String   @id @default(cuid())
  enrollmentId String
  subjectId    String
  teacherId    String
  date         DateTime
  description  String   @db.Text // Actividades de superación
  status       String   @default("PENDING") // PENDING, PASSED, FAILED
  grade        String?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id])
  teacher    Teacher    @relation(fields: [teacherId], references: [id])
}

enum EnrollmentStatus {
  ENROLLED    // Matriculado
  PASSED      // Aprobado/Promovido
  FAILED      // Reprobado
  REMEDIAL    // En proceso de nivelación
  WITHDRAWN   // Retirado
}


model Teacher {
  id              String              @id @default(cuid())
  firstName       String
  lastName        String
  documentId      String?
  phone           String?
  address         String?
  specialization  String?
  userId          String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // --- Campos C-600 DANE ---
  escalafon       String?             // Nivel de escalafón docente
  highestDegree   String?             // Pregrado, Magister, Doctorado
  vinculationType String?             // Planta, Contrato, etc.
  weeklyHours     Int?                // Carga horaria total
  
  attendances     Attendance[]
  attendanceReqs  AttendanceRequest[]
  directedCourses Course[]            @relation("CourseDirector")
  user            User                @relation(fields: [userId], references: [id])
  assignments     TeacherAssignment[]
  observations    Observation[]
  parentMeetings  ParentMeeting[]
  remedialSessions RemedialSession[]
}

model Course {
  id             String              @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  directorId     String?
  attendances    Attendance[]
  attendanceReqs AttendanceRequest[]
  director       Teacher?            @relation("CourseDirector", fields: [directorId], references: [id])
  students       Student[]
  assignments    TeacherAssignment[]
  enrollments    Enrollment[]
  
  nextCourseId   String?
  nextCourse     Course?             @relation("CoursePromotion", fields: [nextCourseId], references: [id])
  previousCourses Course[]            @relation("CoursePromotion")
}

model Subject {
  id              String              @id @default(cuid())
  name            String
  gradingConfigId String
  weeklyHours     Float?              // Intensidad Horaria (I.H.)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  gradingConfig   GradingConfig       @relation(fields: [gradingConfigId], references: [id])
  assignments     TeacherAssignment[]
  remedialSessions RemedialSession[]
  indicators      Indicator[]
}

model TeacherAssignment {
  id             String          @id @default(cuid())
  teacherId      String
  courseId       String
  subjectId      String
  accessRequests AccessRequest[]
  grades         Grade[]
  course         Course          @relation(fields: [courseId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  teacher        Teacher         @relation(fields: [teacherId], references: [id])
  scheduleItems  ScheduleItem[]

  @@unique([teacherId, courseId, subjectId])
}

model AcademicYear {
  id        String           @id @default(cuid())
  name      String
  isActive  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  periods   AcademicPeriod[]
  enrollments Enrollment[]
}

model AcademicPeriod {
  id             String          @id @default(cuid())
  name           String
  weight         Float
  academicYearId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  status         PeriodStatus    @default(OPEN)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  accessRequests AccessRequest[]
  grades         Grade[]
  indicators     Indicator[]
}

model AccessRequest {
  id           String            @id @default(cuid())
  assignmentId String
  periodId     String
  reason       String
  status       RequestStatus     @default(PENDING)
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
}

model SchoolInfo {
  id                  String   @id @default("institutional-info")
  name                String   @default("Nombre del Colegio")
  nit                 String?
  dane                String?
  address             String?
  phone               String?
  email               String?
  rectorName          String?
  license             String?   // Licencia de funcionamiento
  legalStatus         String?   // Personería Jurídica
  
  // --- Datos DANE / Institucionales ---
  daneCode            String?   // Código DANE 12 dígitos
  calendar            String    @default("A") // Calendario A o B
  sector              String    @default("NO_OFICIAL") // OFICIAL o NO_OFICIAL
  consecutivoMatricula Int      @default(1)
  
  logo                String?
  updatedAt           DateTime @updatedAt
  alertThreshold      Float    @default(3.0)
  attendanceLimitDays Int      @default(1)
  conditionalThreshold Int     @default(3) // Número de faltas para matrícula condicional
  sessionTimeout      Int      @default(60) // In minutes
  keepSessionOpen     Boolean  @default(false)
}


model Attendance {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus
  teacherId String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])
  teacher   Teacher?         @relation(fields: [teacherId], references: [id])

  @@unique([studentId, courseId, date])
}

model AttendanceRequest {
  id        String        @id @default(cuid())
  teacherId String
  courseId  String
  date      DateTime
  reason    String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  course    Course        @relation(fields: [courseId], references: [id])
  teacher   Teacher       @relation(fields: [teacherId], references: [id])
}

model GradingConfig {
  id            String    @id @default(cuid())
  name          String
  type          String
  minValue      Float?
  maxValue      Float?
  allowedValues String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  subjects      Subject[]
}

model Grade {
  id           String            @id @default(cuid())
  studentId    String
  assignmentId String
  value        String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  periodId     String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id])
  period       AcademicPeriod    @relation(fields: [periodId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])

  @@unique([studentId, assignmentId, periodId])
}

model Message {
  id          String       @id @default(cuid())
  subject     String
  content     String
  senderId    String
  receiverId  String
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender      User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Attachment {
  id        String  @id @default(cuid())
  name      String
  type      String
  data      String
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Observation {
  id          String          @id @default(cuid())
  studentId   String
  teacherId   String
  date        DateTime        @default(now())
  type        ObservationType
  severity    Severity
  description String          @db.Text

  student    Student         @relation(fields: [studentId], references: [id])
  teacher    Teacher         @relation(fields: [teacherId], references: [id])
  followUps  FollowUp[]
  agreements Agreement[]
  meetings   ParentMeeting[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model FollowUp {
  id            String   @id @default(cuid())
  observationId String
  date          DateTime @default(now())
  description   String   @db.Text

  observation Observation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ParentMeeting {
  id            String        @id @default(cuid())
  studentId     String
  teacherId     String
  date          DateTime
  status        MeetingStatus @default(PENDING)
  notes         String?       @db.Text
  observationId String?

  student     Student      @relation(fields: [studentId], references: [id])
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  observation Observation? @relation(fields: [observationId], references: [id])
  agreements  Agreement[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Agreement {
  id          String   @id @default(cuid())
  description String   @db.Text
  date        DateTime @default(now())

  observationId String?
  observation   Observation? @relation(fields: [observationId], references: [id])

  parentMeetingId String?
  parentMeeting   ParentMeeting? @relation(fields: [parentMeetingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ObservationType {
  CONDUCTUAL
  ACADEMICA
  OTRA
}

enum Severity {
  LEVE
  MODERADA
  GRAVE
}

enum MeetingStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        EventType @default(OTHER)
  isGlobal    Boolean   @default(true)
  targetRole  Role? // If null, visible to all in the scope
  courseId    String?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScheduleItem {
  id           String            @id @default(cuid())
  dayOfWeek    Int
  startTime    String
  endTime      String
  assignmentId String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([dayOfWeek, startTime, assignmentId])
}

enum EventType {
  MEETING
  BULLETIN_DELIVERY
  PEDAGOGICAL_DAY
  HOLIDAY
  OTHER
}

model PasswordResetRequest {
  id           String        @id @default(cuid())
  documentType String
  documentId   String
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// --- Módulo de Tesorería ---

model FeeType {
  id          String    @id @default(cuid())
  name        String    // Ej: "Pensión Mensual", "Matrícula"
  amount      Float
  description String?
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id        String        @id @default(cuid())
  studentId String
  feeTypeId String
  amount    Float         // Amount to be paid
  dueDate   DateTime
  status    InvoiceStatus @default(PENDING)
  month     Int?          // 1-12
  year      Int?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  student  Student   @relation(fields: [studentId], references: [id])
  feeType  FeeType   @relation(fields: [feeTypeId], references: [id])
  payments Payment[]

  @@unique([studentId, feeTypeId, month, year])
}

model Payment {
  id        String      @id @default(cuid())
  invoiceId String
  amount    Float       // Amount paid
  method    String      @default("CASH") // CASH, TRANSFER, CARD
  reference String?     // Bank reference or receipt number
  date      DateTime    @default(now())
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

// --- Módulo de Boletines e Informes ---

model Indicator {
  id               String          @id @default(cuid())
  subjectId        String
  periodId         String
  performanceLevel String          // Superior, Alto, Básico, Bajo
  description      String          @db.Text
  
  subject          Subject         @relation(fields: [subjectId], references: [id])
  period           AcademicPeriod  @relation(fields: [periodId], references: [id])

  @@unique([subjectId, periodId, performanceLevel])
}
